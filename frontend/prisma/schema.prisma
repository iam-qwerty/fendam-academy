// FendAm Academy — Frontend Prisma Schema
// Shared database with backend — better-auth uses this for user/session management

generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// better-auth Required Tables
model User {
  id            String   @id @default(cuid())
  email         String   @unique
  name          String?
  role          String   @default("student")
  emailVerified Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  sessions      Session[]
  accounts      Account[]
  studentProfile StudentProfile?
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Account {
  id                    String    @id @default(cuid())
  userId                String
  accountId             String
  providerId            String
  accessToken           String?
  refreshToken          String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([providerId, accountId])
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

// JWT plugin — stores asymmetric key pairs for signing JWTs
model Jwks {
  id         String   @id @default(cuid())
  publicKey  String
  privateKey String
  createdAt  DateTime @default(now())
}

// Minimal app models needed for frontend queries
model StudentProfile {
  id               String @id @default(cuid())
  userId           String @unique
  trackId          String
  kycStatus        String @default("not_started")
  enrollmentStatus String @default("applied")
  progressPercent  Float  @default(0)
  user             User   @relation(fields: [userId], references: [id])
  track            Track  @relation(fields: [trackId], references: [id])
}

model Track {
  id          String           @id @default(cuid())
  name        String
  description String
  students    StudentProfile[]
}

