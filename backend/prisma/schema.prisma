// FendAm Academy — Prisma Schema
// Matches spec.md §5 exactly

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
}

// ──────────────────────────────────────────────
// better-auth Required Tables
// ──────────────────────────────────────────────

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  name          String?
  image         String?
  role          String   @default("student") // "student" | "instructor" | "admin"
  emailVerified Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // better-auth relations
  sessions Session[]
  accounts Account[]

  // App relations
  studentProfile StudentProfile?
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Account {
  id                    String    @id @default(cuid())
  userId                String
  accountId             String
  providerId            String
  accessToken           String?
  refreshToken          String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  idToken               String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([providerId, accountId])
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

// JWT plugin — stores asymmetric key pairs for signing JWTs
model Jwks {
  id         String   @id @default(cuid())
  publicKey  String
  privateKey String
  createdAt  DateTime @default(now())
}

// ──────────────────────────────────────────────
// Core App Tables
// ──────────────────────────────────────────────

model StudentProfile {
  id               String @id @default(cuid())
  userId           String @unique
  trackId          String
  kycStatus        String @default("not_started")
  enrollmentStatus String @default("applied")
  user             User   @relation(fields: [userId], references: [id])
  track            Track  @relation(fields: [trackId], references: [id])
}

model Track {
  id          String           @id @default(cuid())
  name        String
  description String
  modules     Module[]
  students    StudentProfile[]
}

model Module {
  id          String             @id @default(cuid())
  trackId     String
  title       String
  orderIndex  Int
  track       Track              @relation(fields: [trackId], references: [id])
  lessons     Lesson[]
  assignments Assignment[]
  instructors InstructorModule[]
}

// Join table — admin assigns instructors to modules
model InstructorModule {
  id           String   @id @default(cuid())
  instructorId String // references User.id where role = "instructor"
  moduleId     String
  assignedAt   DateTime @default(now())
  module       Module   @relation(fields: [moduleId], references: [id])

  @@unique([instructorId, moduleId])
}

model Lesson {
  id          String             @id @default(cuid())
  moduleId    String
  title       String
  vimeoId     String // Vimeo video ID only — not a full URL
  resources   Json               @default("[]") // Resource[]: { title, url, type }
  orderIndex  Int                @default(0)
  module      Module             @relation(fields: [moduleId], references: [id])
  completions LessonCompletion[]
}

// Created when a student marks a lesson as complete
model LessonCompletion {
  id          String   @id @default(cuid())
  lessonId    String
  studentId   String
  completedAt DateTime @default(now())
  lesson      Lesson   @relation(fields: [lessonId], references: [id])

  @@unique([lessonId, studentId])
}

model Assignment {
  id           String       @id @default(cuid())
  moduleId     String
  title        String
  instructions String
  dueDate      DateTime
  maxScore     Int
  module       Module       @relation(fields: [moduleId], references: [id])
  submissions  Submission[]
}

model Submission {
  id           String     @id @default(cuid())
  assignmentId String
  studentId    String
  fileUrl      String? // legacy public URL, kept temporarily for backfill only
  fileKey      String
  score        Int?
  feedback     String?
  status       String     @default("submitted") // submitted | graded | returned
  createdAt    DateTime   @default(now())
  assignment   Assignment @relation(fields: [assignmentId], references: [id])

  @@unique([assignmentId, studentId])
}

model KYCRecord {
  id                 String   @id @default(cuid())
  studentId          String
  idCardUrl          String?  // legacy public URL, kept temporarily for backfill only
  idCardFileKey      String
  paymentProofUrl    String?  // legacy public URL, kept temporarily for backfill only
  paymentProofFileKey String
  status             String   @default("submitted") // submitted | under_review | approved | rejected
  reviewComment      String?
  createdAt          DateTime @default(now())
}
