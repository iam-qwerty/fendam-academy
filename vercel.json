{
  "experimentalServices": {
    "frontend": {
      "entrypoint": "frontend",
      "routePrefix": "/",
      "framework": "nextjs"
    },
    "backend": {
      "entrypoint": "backend",
      "routePrefix": "/nest",
      "framework": "nestjs",
      "includeFiles": [
        "backend/node_modules/@prisma/adapter-pg/**",
        "backend/node_modules/pg/**",
        "backend/node_modules/pg-types/**",
        "backend/node_modules/pg-protocol/**",
        "backend/node_modules/pgpass/**",
        "backend/src/generated/prisma/**"
      ]
    }
  }
}